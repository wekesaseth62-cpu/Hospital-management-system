# =========================
# APPOINTMENT FUNCTIONS
# =========================
def schedule_appointment():
    print("\n=== SCHEDULE APPOINTMENT ===")

    view_patients()
    patient_id = get_valid_number("Select Patient ID: ")

    view_staff()
    staff_id = get_valid_number("Select Staff ID: ")

    date = get_valid_date("Date (YYYY-MM-DD): ")
    time = get_valid_time("Time (HH:MM): ")

    c.execute("""
    INSERT INTO appointments (patient_id, staff_id, date, time)
    VALUES (?, ?, ?, ?)
    """, (patient_id, staff_id, date, time))

    conn.commit()

    appointment_id = c.lastrowid

    log_action("ADD", "appointments", appointment_id)

    print("Appointment scheduled successfully.\n")


def view_appointments():
    print("\n=== APPOINTMENTS ===")

    c.execute("""
    SELECT
        appointments.id,
        patients.name,
        staff.name,
        appointments.date,
        appointments.time
    FROM appointments
    JOIN patients ON appointments.patient_id = patients.id
    JOIN staff ON appointments.staff_id = staff.id
    """)

    rows = c.fetchall()

    if rows:
        for row in rows:
            print(row)
    else:
        print("No appointments found.")

    print()


def cancel_appointment():
    print("\n=== CANCEL APPOINTMENT ===")

    appointment_id = get_valid_number("Enter Appointment ID: ")

    c.execute("SELECT * FROM appointments WHERE id=?", (appointment_id,))

    if not c.fetchone():
        print("Appointment not found.\n")
        return

    c.execute("DELETE FROM appointments WHERE id=?", (appointment_id,))

    conn.commit()

    log_action("DELETE", "appointments", appointment_id)

    print("Appointment canceled successfully.\n")


# =========================
# HISTORY FUNCTION
# =========================
def view_history():
    print("\n=== SYSTEM HISTORY ===")

    c.execute("""
    SELECT * FROM history
    ORDER BY timestamp DESC
    """)

    rows = c.fetchall()

    if rows:
        for row in rows:
            print(row)
    else:
        print("No history found.")

    print()


# =========================
# MAIN MENU
# =========================
def main_menu():
    while True:
        print("===================================")
        print(" HOSPITAL MANAGEMENT SYSTEM ")
        print("===================================")
        print("1. Add Patient")
        print("2. View Patients")
        print("3. Update Patient")
        print("4. Delete Patient")
        print("5. Add Staff")
        print("6. View Staff")
        print("7. Update Staff")
        print("8. Delete Staff")
        print("9. Schedule Appointment")
        print("10. View Appointments")
        print("11. Cancel Appointment")
        print("12. View System History")
        print("13. Exit")

        choice = input("Enter choice: ")

        if choice == "1":
            add_patient()

        elif choice == "2":
            view_patients()

        elif choice == "3":
            update_patient()

        elif choice == "4":
            delete_patient()

        elif choice == "5":
            add_staff()

        elif choice == "6":
            view_staff()

        elif choice == "7":
            update_staff()

        elif choice == "8":
            delete_staff()

        elif choice == "9":
            schedule_appointment()

        elif choice == "10":
            view_appointments()

        elif choice == "11":
            cancel_appointment()

        elif choice == "12":
            view_history()

        elif choice == "13":
            print("Exiting system.")
            conn.close()
            break

        else:
            print("Invalid choice.\n")


# =========================
# RUN PROGRAM
# =========================
if __name__ == "__main__":
    main_menu()
